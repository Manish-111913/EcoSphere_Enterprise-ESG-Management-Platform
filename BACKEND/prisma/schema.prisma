// EcoSphere — PostgreSQL schema (Prisma). Source of truth: spec §A3.1–A3.4.
// Conventions: UUID PKs, snake_case tables/columns, soft delete, audit columns,
// business statuses/severities/units live in lookup_values (nothing hardcoded).
// CHECK constraints, lookup FKs and partial indexes are appended in the
// migration SQL (Prisma cannot express CHECKs declaratively).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Structural enums ───────────────────────────
// (Business values — statuses, severities, difficulties, units — are NOT here;
//  they are rows in lookup_values. These enums are structural, not configurable.)

enum SettingValueType {
  string
  number
  boolean
  json
}

enum RecordType {
  PURCHASE
  MANUFACTURING
  EXPENSE
  FLEET
}

enum XpEntryType {
  EARN
  REDEEM
  ADJUST
}

enum XpSourceType {
  CSR
  CHALLENGE
  REDEMPTION
  MANUAL
}

enum CalculationMode {
  AUTO
  MANUAL
}

enum AwardMode {
  AUTO
  MANUAL
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  APPROVE
  REJECT
  TRANSITION
  REDEEM
  EXPORT
  CONFIG_CHANGE
}

enum ReportFormat {
  PDF
  XLSX
  CSV
}

enum ExportStatus {
  Queued
  Ready
  Failed
}

enum MetricDirection {
  higher_better
  lower_better
}

enum ApprovalEntityType {
  CSR_PARTICIPATION
  CHALLENGE_PARTICIPATION
}

enum ApprovalScope {
  ANY
  SAME_DEPARTMENT
}

enum RecipientStrategy {
  ACTOR
  OWNER
  ROLE
  DEPARTMENT_HEAD
  ALL_AFFECTED
}

enum PolicyAudience {
  ALL
  DEPARTMENT
}

enum ScoringPillar {
  E
  S
  G
}

// ═══════════════════ A3.1 Identity, RBAC & Auth ═══════════════════

model User {
  id              String    @id @default(uuid()) @db.Uuid
  employeeCode    String    @unique @map("employee_code")
  firstName       String    @map("first_name")
  lastName        String    @map("last_name")
  email           String    @unique
  passwordHash    String    @map("password_hash")
  departmentId    String    @map("department_id") @db.Uuid
  designation     String?
  joinDate        DateTime? @map("join_date") @db.Date
  avatarKey       String?   @map("avatar_key")
  emailVerifiedAt DateTime? @map("email_verified_at")
  isActive        Boolean   @default(true) @map("is_active")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  createdBy       String?   @map("created_by") @db.Uuid
  updatedAt       DateTime  @updatedAt @map("updated_at")
  updatedBy       String?   @map("updated_by") @db.Uuid
  deletedAt       DateTime? @map("deleted_at")

  department            Department              @relation(fields: [departmentId], references: [id])
  userRoles             UserRole[]
  refreshTokens         RefreshToken[]
  passwordResetTokens   PasswordResetToken[]
  csrParticipations     CsrParticipation[]
  challengeParticipations ChallengeParticipation[]
  xpLedger              XpLedger[]
  badgeAwards           BadgeAward[]
  rewardRedemptions     RewardRedemption[]
  policyAcknowledgements PolicyAcknowledgement[]
  trainingRecords       TrainingRecord[]
  notifications         Notification[]

  @@index([departmentId])
  @@map("users")
}

model Role {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique
  description String?
  isSystem    Boolean @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id       String @id @default(uuid()) @db.Uuid
  resource String
  action   String

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Invitation {
  id           String    @id @default(uuid()) @db.Uuid
  email        String
  roleId       String    @map("role_id") @db.Uuid
  departmentId String    @map("department_id") @db.Uuid
  tokenHash    String    @unique @map("token_hash")
  invitedBy    String    @map("invited_by") @db.Uuid
  expiresAt    DateTime  @map("expires_at")
  acceptedAt   DateTime? @map("accepted_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([email])
  @@map("invitations")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ═══════════════════ A3.2 Configuration & Lookups ═══════════════════

model AppSetting {
  key         String           @id
  value       String?
  valueType   SettingValueType @map("value_type")
  category    String?
  description String?
  isPublic    Boolean          @default(false) @map("is_public")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  updatedBy   String?          @map("updated_by") @db.Uuid

  @@map("app_settings")
}

model LookupType {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")

  values LookupValue[]

  @@map("lookup_types")
}

model LookupValue {
  id           String   @id @default(uuid()) @db.Uuid
  lookupTypeId String   @map("lookup_type_id") @db.Uuid
  code         String
  label        String
  color        String?
  sortOrder    Int      @default(0) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  lookupType LookupType @relation(fields: [lookupTypeId], references: [id])

  @@unique([lookupTypeId, code])
  @@index([lookupTypeId])
  @@map("lookup_values")
}

// State machines as data (from/to reference lookup_values via raw-SQL FKs).
model LookupTransition {
  id               String  @id @default(uuid()) @db.Uuid
  lookupTypeId     String  @map("lookup_type_id") @db.Uuid
  fromValueId      String  @map("from_value_id") @db.Uuid
  toValueId        String  @map("to_value_id") @db.Uuid
  allowedPermission String? @map("allowed_permission")

  @@unique([fromValueId, toValueId])
  @@index([lookupTypeId])
  @@map("lookup_transitions")
}

model EsgWeightConfig {
  id                  String    @id @default(uuid()) @db.Uuid
  environmentalWeight Int       @map("environmental_weight")
  socialWeight        Int       @map("social_weight")
  governanceWeight    Int       @map("governance_weight")
  effectiveFrom       DateTime  @map("effective_from") @db.Date
  effectiveTo         DateTime? @map("effective_to") @db.Date
  isActive            Boolean   @default(true) @map("is_active")
  createdAt           DateTime  @default(now()) @map("created_at")

  @@map("esg_weight_configs")
}

model ScoringConfig {
  id            String        @id @default(uuid()) @db.Uuid
  pillar        ScoringPillar
  metricCode    String        @map("metric_code")
  weight        Int
  normalization Json
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")

  @@unique([pillar, metricCode])
  @@map("scoring_configs")
}

model ApprovalRule {
  id                      String             @id @default(uuid()) @db.Uuid
  entityType              ApprovalEntityType @map("entity_type")
  approverRoleId          String             @map("approver_role_id") @db.Uuid
  scope                   ApprovalScope      @default(ANY)
  evidenceRequiredOverride Boolean?          @map("evidence_required_override")
  isActive                Boolean            @default(true) @map("is_active")
  createdAt               DateTime           @default(now()) @map("created_at")

  @@index([entityType])
  @@map("approval_rules")
}

model NotificationTemplate {
  id              String   @id @default(uuid()) @db.Uuid
  code            String   @unique
  titleTemplate   String   @map("title_template")
  bodyTemplate    String   @map("body_template")
  channelDefaults Json?    @map("channel_defaults")
  createdAt       DateTime @default(now()) @map("created_at")

  rules NotificationRule[]

  @@map("notification_templates")
}

model NotificationRule {
  id                String            @id @default(uuid()) @db.Uuid
  eventCode         String            @map("event_code")
  templateId        String            @map("template_id") @db.Uuid
  channels          Json
  recipientStrategy RecipientStrategy @map("recipient_strategy")
  recipientRoleId   String?           @map("recipient_role_id") @db.Uuid
  scheduleCron      String?           @map("schedule_cron")
  isEnabled         Boolean           @default(true) @map("is_enabled")
  createdAt         DateTime          @default(now()) @map("created_at")

  template NotificationTemplate @relation(fields: [templateId], references: [id])

  @@index([eventCode])
  @@map("notification_rules")
}

model DashboardWidgetConfig {
  id         String  @id @default(uuid()) @db.Uuid
  roleId     String  @map("role_id") @db.Uuid
  widgetCode String  @map("widget_code")
  position   Int     @default(0)
  isVisible  Boolean @default(true) @map("is_visible")
  config     Json?

  @@unique([roleId, widgetCode])
  @@map("dashboard_widget_configs")
}

model ReportTemplate {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  ownerId      String?  @map("owner_id") @db.Uuid
  moduleScope  Json     @map("module_scope")
  columns      Json
  filters      Json?
  groupBy      Json?    @map("group_by")
  aggregations Json?
  chartType    String?  @map("chart_type")
  isShared     Boolean  @default(false) @map("is_shared")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("report_templates")
}

model MetricDefinition {
  id        String          @id @default(uuid()) @db.Uuid
  code      String          @unique
  name      String
  unit      String?
  direction MetricDirection
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")

  diversityRecords DiversityMetricRecord[]

  @@map("metric_definitions")
}

// ═══════════════════ A3.3 Master Tables ═══════════════════

model Department {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String
  code               String   @unique
  headUserId         String?  @map("head_user_id") @db.Uuid
  parentDepartmentId String?  @map("parent_department_id") @db.Uuid
  employeeCount      Int      @default(0) @map("employee_count")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  createdBy          String?  @map("created_by") @db.Uuid
  updatedAt          DateTime @updatedAt @map("updated_at")
  updatedBy          String?  @map("updated_by") @db.Uuid
  deletedAt          DateTime? @map("deleted_at")

  parent   Department?  @relation("DeptHierarchy", fields: [parentDepartmentId], references: [id], onDelete: Restrict)
  children Department[] @relation("DeptHierarchy")
  users    User[]

  @@index([parentDepartmentId])
  @@map("departments")
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  type        String // CSR_ACTIVITY | CHALLENGE (structural pair, unique with name)
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  csrActivities CsrActivity[]
  challenges    Challenge[]

  @@unique([name, type])
  @@map("categories")
}

model EmissionFactor {
  id              String    @id @default(uuid()) @db.Uuid
  name            String
  category        String
  unitId          String    @map("unit_id") @db.Uuid
  scopeId         String    @map("scope_id") @db.Uuid
  factorValue     Decimal   @map("factor_value") @db.Decimal(14, 6)
  sourceReference String?   @map("source_reference")
  effectiveFrom   DateTime  @map("effective_from") @db.Date
  effectiveTo     DateTime? @map("effective_to") @db.Date
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  carbonTransactions CarbonTransaction[]

  @@index([category, unitId, effectiveFrom])
  @@map("emission_factors")
}

model Product {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  sku       String   @unique
  category  String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  esgProfile ProductEsgProfile?

  @@map("products")
}

model ProductEsgProfile {
  id                    String   @id @default(uuid()) @db.Uuid
  productId             String   @unique @map("product_id") @db.Uuid
  carbonFootprintPerUnit Decimal? @map("carbon_footprint_per_unit") @db.Decimal(14, 6)
  recyclabilityPct      Decimal? @map("recyclability_pct") @db.Decimal(5, 2)
  sustainabilityRating  String?  @map("sustainability_rating")
  certifications        Json?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_esg_profiles")
}

model EnvironmentalGoal {
  id            String    @id @default(uuid()) @db.Uuid
  title         String
  departmentId  String?   @map("department_id") @db.Uuid
  metricCode    String    @map("metric_code")
  targetValue   Decimal   @map("target_value") @db.Decimal(18, 4)
  baselineValue Decimal?  @map("baseline_value") @db.Decimal(18, 4)
  unitId        String?   @map("unit_id") @db.Uuid
  periodStart   DateTime  @map("period_start") @db.Date
  periodEnd     DateTime  @map("period_end") @db.Date
  statusId      String?   @map("status_id") @db.Uuid
  progressPct   Decimal?  @map("progress_pct") @db.Decimal(5, 2)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  @@index([departmentId])
  @@map("environmental_goals")
}

model EsgPolicy {
  id                       String         @id @default(uuid()) @db.Uuid
  title                    String
  description              String?
  version                  Int            @default(1)
  documentAttachmentId     String?        @map("document_attachment_id") @db.Uuid
  effectiveDate            DateTime?      @map("effective_date") @db.Date
  acknowledgementDeadline  DateTime?      @map("acknowledgement_deadline") @db.Date
  audience                 PolicyAudience @default(ALL)
  audienceDepartmentId     String?        @map("audience_department_id") @db.Uuid
  statusId                 String?        @map("status_id") @db.Uuid
  publishedAt              DateTime?      @map("published_at")
  publishedBy              String?        @map("published_by") @db.Uuid
  createdAt                DateTime       @default(now()) @map("created_at")
  updatedAt                DateTime       @updatedAt @map("updated_at")
  deletedAt                DateTime?      @map("deleted_at")

  acknowledgements PolicyAcknowledgement[]

  @@map("esg_policies")
}

model Badge {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  iconKey     String?  @map("icon_key")
  unlockRule  Json     @map("unlock_rule")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  awards BadgeAward[]

  @@map("badges")
}

model Reward {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  description    String?
  pointsRequired Int      @map("points_required")
  stock          Int      @default(0)
  imageKey       String?  @map("image_key")
  statusId       String?  @map("status_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  redemptions RewardRedemption[]

  @@map("rewards")
}

// ═══════════════════ A3.4 Transaction Tables ═══════════════════

model OperationalRecord {
  id               String     @id @default(uuid()) @db.Uuid
  recordType       RecordType @map("record_type")
  departmentId     String     @map("department_id") @db.Uuid
  description      String?
  quantity         Decimal    @db.Decimal(18, 4)
  unitId           String     @map("unit_id") @db.Uuid
  amount           Decimal?   @db.Decimal(18, 2)
  occurredAt       DateTime   @map("occurred_at") @db.Date
  externalRef      String?    @map("external_ref")
  emissionCategory String?    @map("emission_category")
  createdAt        DateTime   @default(now()) @map("created_at")
  createdBy        String?    @map("created_by") @db.Uuid
  updatedAt        DateTime   @updatedAt @map("updated_at")
  deletedAt        DateTime?  @map("deleted_at")

  carbonTransaction CarbonTransaction?

  @@index([recordType, occurredAt])
  @@index([departmentId])
  @@map("operational_records")
}

model CarbonTransaction {
  id                   String          @id @default(uuid()) @db.Uuid
  operationalRecordId  String?         @unique @map("operational_record_id") @db.Uuid
  departmentId         String          @map("department_id") @db.Uuid
  emissionFactorId     String          @map("emission_factor_id") @db.Uuid
  factorValueSnapshot  Decimal         @map("factor_value_snapshot") @db.Decimal(14, 6)
  quantity             Decimal         @db.Decimal(18, 4)
  unitId               String          @map("unit_id") @db.Uuid
  co2eKg               Decimal         @map("co2e_kg") @db.Decimal(18, 4)
  calculationMode      CalculationMode @map("calculation_mode")
  occurredAt           DateTime        @map("occurred_at") @db.Date
  notes                String?
  createdAt            DateTime        @default(now()) @map("created_at")
  createdBy            String?         @map("created_by") @db.Uuid
  updatedAt            DateTime        @updatedAt @map("updated_at")
  deletedAt            DateTime?       @map("deleted_at")

  operationalRecord OperationalRecord? @relation(fields: [operationalRecordId], references: [id])
  emissionFactor    EmissionFactor     @relation(fields: [emissionFactorId], references: [id])

  @@index([departmentId, occurredAt])
  @@index([emissionFactorId])
  @@map("carbon_transactions")
}

model CsrActivity {
  id                       String    @id @default(uuid()) @db.Uuid
  title                    String
  categoryId               String    @map("category_id") @db.Uuid
  description              String?
  departmentId             String?   @map("department_id") @db.Uuid
  location                 String?
  startDate                DateTime  @map("start_date") @db.Date
  endDate                  DateTime  @map("end_date") @db.Date
  capacity                 Int?
  pointsValue              Int       @default(0) @map("points_value")
  evidenceRequiredOverride Boolean?  @map("evidence_required_override")
  statusId                 String?   @map("status_id") @db.Uuid
  createdAt                DateTime  @default(now()) @map("created_at")
  createdBy                String?   @map("created_by") @db.Uuid
  updatedAt                DateTime  @updatedAt @map("updated_at")
  deletedAt                DateTime? @map("deleted_at")

  category       Category           @relation(fields: [categoryId], references: [id])
  participations CsrParticipation[]

  @@index([categoryId])
  @@index([departmentId])
  @@map("csr_activities")
}

model CsrParticipation {
  id                 String    @id @default(uuid()) @db.Uuid
  csrActivityId      String    @map("csr_activity_id") @db.Uuid
  employeeId         String    @map("employee_id") @db.Uuid
  statusId           String?   @map("status_id") @db.Uuid
  proofAttachmentId  String?   @map("proof_attachment_id") @db.Uuid
  pointsEarned       Int?      @map("points_earned")
  completionDate     DateTime? @map("completion_date") @db.Date
  decidedBy          String?   @map("decided_by") @db.Uuid
  decidedAt          DateTime? @map("decided_at")
  decisionRemarks    String?   @map("decision_remarks")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  activity CsrActivity @relation(fields: [csrActivityId], references: [id])
  employee User        @relation(fields: [employeeId], references: [id])

  @@unique([csrActivityId, employeeId])
  @@index([employeeId])
  @@map("csr_participations")
}

model Challenge {
  id               String    @id @default(uuid()) @db.Uuid
  title            String
  categoryId       String    @map("category_id") @db.Uuid
  description      String?
  xpValue          Int       @map("xp_value")
  difficultyId     String?   @map("difficulty_id") @db.Uuid
  evidenceRequired Boolean   @default(false) @map("evidence_required")
  startDate        DateTime  @map("start_date") @db.Date
  deadline         DateTime  @db.Date
  statusId         String?   @map("status_id") @db.Uuid
  createdBy        String?   @map("created_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  category       Category                 @relation(fields: [categoryId], references: [id])
  participations ChallengeParticipation[]

  @@index([categoryId])
  @@map("challenges")
}

model ChallengeParticipation {
  id                String    @id @default(uuid()) @db.Uuid
  challengeId       String    @map("challenge_id") @db.Uuid
  employeeId        String    @map("employee_id") @db.Uuid
  progressPct       Int       @default(0) @map("progress_pct")
  proofAttachmentId String?   @map("proof_attachment_id") @db.Uuid
  statusId          String?   @map("status_id") @db.Uuid
  xpAwarded         Int?      @map("xp_awarded")
  decidedBy         String?   @map("decided_by") @db.Uuid
  decidedAt         DateTime? @map("decided_at")
  decisionRemarks   String?   @map("decision_remarks")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  challenge Challenge @relation(fields: [challengeId], references: [id])
  employee  User      @relation(fields: [employeeId], references: [id])

  @@unique([challengeId, employeeId])
  @@index([employeeId])
  @@map("challenge_participations")
}

// Append-only single points currency (XP = Points). Never UPDATE/DELETE.
model XpLedger {
  id           String       @id @default(uuid()) @db.Uuid
  employeeId   String       @map("employee_id") @db.Uuid
  entryType    XpEntryType  @map("entry_type")
  points       Int
  sourceType   XpSourceType @map("source_type")
  sourceId     String?      @map("source_id") @db.Uuid
  balanceAfter Int          @map("balance_after")
  remarks      String?
  createdAt    DateTime     @default(now()) @map("created_at")

  employee User @relation(fields: [employeeId], references: [id])

  @@unique([sourceType, sourceId, entryType]) // idempotency: exactly one grant per approval
  @@index([employeeId, createdAt])
  @@map("xp_ledger")
}

model BadgeAward {
  id           String    @id @default(uuid()) @db.Uuid
  badgeId      String    @map("badge_id") @db.Uuid
  employeeId   String    @map("employee_id") @db.Uuid
  awardedAt    DateTime  @default(now()) @map("awarded_at")
  awardedMode  AwardMode @map("awarded_mode")
  ruleSnapshot Json?     @map("rule_snapshot")

  badge    Badge @relation(fields: [badgeId], references: [id])
  employee User  @relation(fields: [employeeId], references: [id])

  @@unique([badgeId, employeeId]) // race safety
  @@index([employeeId])
  @@map("badge_awards")
}

model RewardRedemption {
  id           String    @id @default(uuid()) @db.Uuid
  rewardId     String    @map("reward_id") @db.Uuid
  employeeId   String    @map("employee_id") @db.Uuid
  pointsSpent  Int       @map("points_spent")
  statusId     String?   @map("status_id") @db.Uuid
  redeemedAt   DateTime  @default(now()) @map("redeemed_at")
  fulfilledAt  DateTime? @map("fulfilled_at")
  fulfilledBy  String?   @map("fulfilled_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")

  reward   Reward @relation(fields: [rewardId], references: [id])
  employee User   @relation(fields: [employeeId], references: [id])

  @@index([rewardId])
  @@index([employeeId])
  @@map("reward_redemptions")
}

model PolicyAcknowledgement {
  id             String   @id @default(uuid()) @db.Uuid
  policyId       String   @map("policy_id") @db.Uuid
  policyVersion  Int      @map("policy_version")
  employeeId     String   @map("employee_id") @db.Uuid
  acknowledgedAt DateTime @default(now()) @map("acknowledged_at")
  ipAddress      String?  @map("ip_address")

  policy   EsgPolicy @relation(fields: [policyId], references: [id])
  employee User      @relation(fields: [employeeId], references: [id])

  @@unique([policyId, policyVersion, employeeId])
  @@index([employeeId])
  @@map("policy_acknowledgements")
}

model GovernanceAudit {
  id               String    @id @default(uuid()) @db.Uuid
  title            String
  auditType        String?   @map("audit_type")
  scopeDescription String?   @map("scope_description")
  departmentId     String?   @map("department_id") @db.Uuid
  auditorId        String    @map("auditor_id") @db.Uuid
  plannedStart     DateTime? @map("planned_start") @db.Date
  plannedEnd       DateTime? @map("planned_end") @db.Date
  actualStart      DateTime? @map("actual_start") @db.Date
  actualEnd        DateTime? @map("actual_end") @db.Date
  statusId         String?   @map("status_id") @db.Uuid
  findingsSummary  String?   @map("findings_summary")
  auditScore       Int?      @map("audit_score")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  complianceIssues ComplianceIssue[]

  @@index([departmentId])
  @@map("governance_audits")
}

model ComplianceIssue {
  id                String    @id @default(uuid()) @db.Uuid
  governanceAuditId String?   @map("governance_audit_id") @db.Uuid
  title             String
  description       String
  severityId        String    @map("severity_id") @db.Uuid
  ownerId           String    @map("owner_id") @db.Uuid
  dueDate           DateTime  @map("due_date") @db.Date
  raisedBy          String?   @map("raised_by") @db.Uuid
  raisedDate        DateTime  @default(now()) @map("raised_date") @db.Date
  statusId          String?   @map("status_id") @db.Uuid
  isOverdue         Boolean   @default(false) @map("is_overdue")
  resolutionNotes   String?   @map("resolution_notes")
  resolvedAt        DateTime? @map("resolved_at")
  closedAt          DateTime? @map("closed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  governanceAudit GovernanceAudit? @relation(fields: [governanceAuditId], references: [id])

  @@index([statusId, dueDate])
  @@index([ownerId])
  @@map("compliance_issues")
}

model DepartmentScore {
  id                   String   @id @default(uuid()) @db.Uuid
  departmentId         String   @map("department_id") @db.Uuid
  periodStart          DateTime @map("period_start") @db.Date
  periodEnd            DateTime @map("period_end") @db.Date
  environmentalScore   Decimal  @map("environmental_score") @db.Decimal(5, 2)
  socialScore          Decimal  @map("social_score") @db.Decimal(5, 2)
  governanceScore      Decimal  @map("governance_score") @db.Decimal(5, 2)
  totalScore           Decimal  @map("total_score") @db.Decimal(5, 2)
  weightConfigSnapshot Json     @map("weight_config_snapshot")
  metricBreakdown      Json     @map("metric_breakdown")
  computedAt           DateTime @default(now()) @map("computed_at")

  @@unique([departmentId, periodStart, periodEnd])
  @@index([departmentId])
  @@map("department_scores")
}

model DiversityMetricRecord {
  id                 String   @id @default(uuid()) @db.Uuid
  departmentId       String?  @map("department_id") @db.Uuid
  metricDefinitionId String   @map("metric_definition_id") @db.Uuid
  period             DateTime @db.Date
  value              Decimal  @db.Decimal(18, 4)
  metadata           Json?
  createdAt          DateTime @default(now()) @map("created_at")

  metricDefinition MetricDefinition @relation(fields: [metricDefinitionId], references: [id])

  @@index([metricDefinitionId])
  @@index([departmentId])
  @@map("diversity_metric_records")
}

model TrainingRecord {
  id           String    @id @default(uuid()) @db.Uuid
  employeeId   String    @map("employee_id") @db.Uuid
  trainingName String    @map("training_name")
  completedAt  DateTime? @map("completed_at") @db.Date
  hours        Decimal?  @db.Decimal(6, 2)
  statusId     String?   @map("status_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")

  employee User @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@map("training_records")
}

model Notification {
  id         String              @id @default(uuid()) @db.Uuid
  userId     String              @map("user_id") @db.Uuid
  ruleId     String?             @map("rule_id") @db.Uuid
  title      String
  body       String?
  eventCode  String?             @map("event_code")
  entityType String?             @map("entity_type")
  entityId   String?             @map("entity_id") @db.Uuid
  channel    NotificationChannel @default(IN_APP)
  isRead     Boolean             @default(false) @map("is_read")
  readAt     DateTime?           @map("read_at")
  createdAt  DateTime            @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

model Attachment {
  id           String   @id @default(uuid()) @db.Uuid
  entityType   String   @map("entity_type")
  entityId     String?  @map("entity_id") @db.Uuid
  fileKey      String   @map("file_key")
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  sizeBytes    Int      @map("size_bytes")
  uploadedBy   String?  @map("uploaded_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@map("attachments")
}

// System trail, append-only.
model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  actorId    String?     @map("actor_id") @db.Uuid
  action     AuditAction
  entityType String?     @map("entity_type")
  // free-text: some entities key on non-UUID ids (settings key, "bulk", etc.)
  entityId   String?     @map("entity_id")
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?     @map("user_agent")
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}

model ReportExport {
  id          String       @id @default(uuid()) @db.Uuid
  requestedBy String?      @map("requested_by") @db.Uuid
  templateId  String?      @map("template_id") @db.Uuid
  format      ReportFormat
  filters     Json?
  fileKey     String?      @map("file_key")
  status      ExportStatus @default(Queued)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@map("report_exports")
}
